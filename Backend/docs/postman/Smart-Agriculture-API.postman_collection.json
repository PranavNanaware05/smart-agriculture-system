              "body": "{\n  \"id\": 1,\n  \"fullName\": \"Ravi Kumar\",\n  \"email\": \"ravi@example.com\",\n  \"role\": \"FARMER\",\n  \"phoneNumber\": \"+919876543210\",\n  \"enabled\": true,\n  \"createdAt\": \"2026-05-14T10:00:00Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "03 Farmers",
      "item": [
        {
          "name": "Create farmer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": null,\n  \"farmerName\": \"Ravi Kumar\",\n  \"village\": \"Nelamangala\",\n  \"district\": \"Bangalore Rural\",\n  \"state\": \"Karnataka\",\n  \"landArea\": 12.5,\n  \"soilType\": \"Red loam\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/farmers",
            "description": "**FARMER:** omit `userId` (uses current user). **ADMIN:** set `userId` to the target FARMER user id."
          },
          "response": [
            {
              "name": "201 Created — sample",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "{\n  \"id\": 1,\n  \"userId\": 1,\n  \"farmerName\": \"Ravi Kumar\",\n  \"village\": \"Nelamangala\",\n  \"district\": \"Bangalore Rural\",\n  \"state\": \"Karnataka\",\n  \"landArea\": 12.5,\n  \"soilType\": \"Red loam\"\n}"
            }
          ]
        },
        {
          "name": "List all farmers (ADMIN only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/farmers"
          },
          "response": [
            {
              "name": "200 OK — sample",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
