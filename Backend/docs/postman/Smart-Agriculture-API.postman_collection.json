        },
        {
          "name": "Update farmer",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": null,\n  \"farmerName\": \"Ravi Kumar\",\n  \"village\": \"Nelamangala\",\n  \"district\": \"Bangalore Rural\",\n  \"state\": \"Karnataka\",\n  \"landArea\": 13,\n  \"soilType\": \"Red loam\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/farmers/{{farmerId}}"
          }
        },
        {
          "name": "Delete farmer",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/farmers/{{farmerId}}"
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "_postman_previewlanguage": "Text",
              "header": [],
              "cookie": [],
              "body": ""
            }
